# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.Python

# Virtual environment
venv/
.venv/
env/
ENV/

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite DB ที่ generate ขึ้นเองตอน run — ไม่ควร commit
backend/bank_statements.db
backend/*.db
*.sqlite3
*.sqlite3-journal

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Dependencies — ติดตั้งใหม่ได้ด้วย npm install
frontend/node_modules/

# Build output — generate ได้ด้วย npm run build
frontend/dist/

# Package manager lock files (เลือกเก็บแค่อันที่ใช้จริง)
# ถ้าใช้ npm → เก็บ package-lock.json, ลบ pnpm-lock.yaml
frontend/pnpm-lock.yaml

# ─── ไฟล์ข้อมูลส่วนตัว / ทดสอบ ────────────────────────────────────────────────
# PDF และ CSV ที่ใช้ทดสอบส่วนตัว — ไม่ควรขึ้น repo
*.pdf
*.csv

# ─── Editor & IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Cursor AI
.cursorignore
.cursorindexingignore

# ─── Environment Variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
pip-log.txt

# ─── Test / Coverage ──────────────────────────────────────────────────────────
htmlcov/
.coverage
.pytest_cache/
.ruff_cache/
